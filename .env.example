# ============================================================================
#  NOIAN BAGS — ORTAM DEĞİŞKENLERİ (ÖRNEK)
# ============================================================================
#  Bu değişkenleri Vercel panelinde (Project → Settings → Environment Variables)
#  tanımlayın. Lokal geliştirme için bu dosyayı ".env" olarak kopyalayabilirsiniz.
#  ".env" gizlidir ve Git'e gönderilmez.
# ============================================================================

# ---- VERİTABANI (Neon Postgres) ----
# Neon panelinden "Connection string" (pooled) değerini kopyalayın.
# Örn: postgresql://kullanici:sifre@ep-xxx.eu-central-1.aws.neon.tech/neondb?sslmode=require
DATABASE_URL=

# ---- ADMIN PANELİ ----
# Yönetim paneline giriş şifresi. Güçlü bir şifre seçin.
ADMIN_PASSWORD=
# Oturum imzalama için rastgele uzun bir gizli anahtar (örn. 32+ karakter).
ADMIN_SESSION_SECRET=

# ---- GÖRSEL DEPOLAMA (Vercel Blob) ----
# Vercel'de bir Blob deposu bağladığınızda bu değişken OTOMATİK eklenir.
# Manuel deneme için token'ı buraya koyabilirsiniz.
BLOB_READ_WRITE_TOKEN=

# ---- SİPARİŞ E-POSTASI (Resend) ----
# https://resend.com — API anahtarı ve gönderen adresi
RESEND_API_KEY=
# Doğrulanmış alan adınızla: Noian Bags <siparis@noian.com.tr>
ORDER_FROM_EMAIL=

# ---- ÖDEME (Shopier) ----
# "test" = demo modu (gerçek tahsilat yok) | "live" = gerçek ödeme
VITE_SHOPIER_MODE=test
# NOT: Shopier API anahtarları istemcide DEĞİL, sunucu (Edge/Serverless)
# tarafında saklanmalıdır. Bkz. src/lib/payment.ts
